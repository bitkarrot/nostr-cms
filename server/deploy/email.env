# nostr-cms email service — environment template (SRV-04)
#
# Copy to server/deploy/email.env (or your chosen location) and fill in the
# values for your deployment. This file is referenced by the systemd unit
# (nostr-cms-email.service) via EnvironmentFile=. No secrets are included
# here — RESEND_API_KEY is added in Phase 2 when the send pipeline lands.
#
# This is a TEMPLATE — edit before use.

# Port the email service listens on (D-01: default 3001).
# nginx proxies /api/email/* to 127.0.0.1:${EMAIL_PORT}.
EMAIL_PORT=3001

# SQLite database file path. Default: ./email.db (relative to WorkingDirectory).
# For production, use an absolute path like /app/email.db.
EMAIL_DB_PATH=/app/email.db

# Database backend: "sqlite" (default, better-sqlite3) or "postgres" (future).
EMAIL_DB_BACKEND=sqlite

# Directory for daily online backups (better-sqlite3 backup API).
# Backups rotate with 7-day retention (see server/db/backup.ts).
EMAIL_BACKUP_DIR=/app/backups

# Master pubkey (hex) authorized to make admin requests via NIP-98.
# If unset, the server falls back to fetching /.well-known/nostr.json
# from SWARM_BASE_URL and reading names._ .
MASTER_PUBKEY=

# Base URL of the swarm relay (for nostr.json master-pubkey fallback and
# future relay WS reads). Include the scheme, no trailing slash.
SWARM_BASE_URL=https://relay.example.com
