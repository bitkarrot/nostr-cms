# Remote nostr.json for admin authentication
# If not set, defaults to /.well-known/nostr.json (same domain)
VITE_REMOTE_NOSTR_JSON_URL=

# Default relay for reading content
# If not set, it auto-derives from current window location
VITE_DEFAULT_RELAY=

# Master pubkey (owner of the site)
VITE_MASTER_PUBKEY=

# Swarm API URL (for scheduled posts feature)
# If not set, it defaults to /api assuming proxy or same-host deployment
# Example: https://swarm.hivetalk.org/api
VITE_SWARM_API_URL=
